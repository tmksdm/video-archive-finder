<Window x:Class="VideoArchiveFinder.Desktop.Views.UncPathDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление сетевого источника"
        Width="540"
        SizeToContent="Height"
        MinWidth="440"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Text="Сетевой UNC-путь"/>

        <TextBlock Grid.Row="1"
                   Margin="0,10,0,0"
                   Foreground="#4B5563"
                   TextWrapping="Wrap"
                   Text="Введите полный путь к общей сетевой папке. Приложение сохранит путь, но пока не будет проверять его доступность."/>

        <TextBox x:Name="PathTextBox"
                 Grid.Row="2"
                 Height="36"
                 Margin="0,14,0,0"
                 Padding="8,5"
                 VerticalContentAlignment="Center"
                 FontSize="14"
                 TextChanged="PathTextBox_TextChanged"
                 ToolTip="Например: \\server\share\video"/>

        <TextBlock x:Name="ValidationText"
                   Grid.Row="3"
                   Margin="0,7,0,0"
                   Foreground="#B91C1C"
                   Text="Введите UNC-путь вида \\server\share или \\server\share\folder"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"/>

        <StackPanel Grid.Row="4"
                    Margin="0,18,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">

            <Button Width="100"
                    Height="34"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Content="Отмена"/>

            <Button Width="100"
                    Height="34"
                    IsDefault="True"
                    Click="AddButton_Click"
                    Content="Добавить"/>
        </StackPanel>
    </Grid>
</Window>
