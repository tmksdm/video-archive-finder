<Window x:Class="VideoArchiveFinder.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Video Archive Finder"
        Width="1280"
        Height="800"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F3F4F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Height="40"
                         Padding="12,6"
                         VerticalContentAlignment="Center"
                         FontSize="16"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Поиск по названиям папок"/>

                <Button Grid.Column="1"
        Width="40"
        Height="40"
        Margin="8,0,0,0"
        ToolTip="Настройки"
        AutomationProperties.Name="Настройки">
                    <materialDesign:PackIcon Kind="Cog"
                             Width="20"
                             Height="20"/>
                </Button>

            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" MinWidth="220"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="3.8*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="12"
                    Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
      Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
               VerticalAlignment="Center"
               FontSize="17"
               FontWeight="SemiBold"
               Text="Источники"/>

                        <Button Grid.Column="1"
            Width="32"
            Height="32"
            Padding="4"
            Command="{Binding AddLocalFolderCommand}"
            ToolTip="Добавить локальную папку"
            AutomationProperties.Name="Добавить локальную папку">
                            <materialDesign:PackIcon Width="19"
                                 Height="19"
                                 Kind="FolderPlus"/>
                        </Button>

                        <Button Grid.Column="2"
            Width="32"
            Height="32"
            Margin="4,0,0,0"
            Padding="4"
            Command="{Binding AddUncPathCommand}"
            ToolTip="Добавить сетевой UNC-путь"
            AutomationProperties.Name="Добавить сетевой UNC-путь">
                            <materialDesign:PackIcon Width="19"
                                 Height="19"
                                 Kind="Lan"/>
                        </Button>
                    </Grid>




                    <Grid Grid.Row="1">
                        <TextBlock HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="#6B7280"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Text="Загрузка источников архива...">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility"
                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoadingSources}"
                                     Value="True">
                                            <Setter Property="Visibility"
                                    Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="#6B7280"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Text="Источники архива пока не добавлены">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility"
                            Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoadingSources}"
                                     Value="True">
                                            <Setter Property="Visibility"
                                    Value="Collapsed"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding HasSources}"
                                     Value="True">
                                            <Setter Property="Visibility"
                                    Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ListBox x:Name="ArchiveSourcesList"
         ItemsSource="{Binding Sources}"
         SelectionMode="Extended"
         PreviewKeyDown="ArchiveSourcesList_PreviewKeyDown"
                 BorderThickness="0"
                 Background="Transparent"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling">

                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility"
                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSources}"
                                     Value="True">
                                            <Setter Property="Visibility"
                                    Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>

                            <ListBox.ItemTemplate>
                                <DataTemplate>


                                    <Grid Margin="4,6"
      Background="Transparent"
      PreviewMouseRightButtonDown="ArchiveSourceCard_PreviewMouseRightButtonDown">


                                        <Grid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Удалить выбранные источники из приложения…"
          Foreground="#B91C1C"
          Click="RemoveSelectedArchiveSources_Click">

                                                    <MenuItem.Icon>
                                                        <materialDesign:PackIcon Width="16"
                                         Height="16"
                                         Foreground="#B91C1C"
                                         Kind="Delete"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Grid.ContextMenu>


                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                       FontWeight="SemiBold"
                       Text="{Binding DisplayName}"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding DisplayName}"/>

                                        <StackPanel Grid.Row="1"
                        Margin="0,3,0,0"
                        Orientation="Horizontal">
                                            <TextBlock VerticalAlignment="Center"
                           Foreground="#6B7280"
                           FontSize="12"
                           Text="{Binding SourceTypeShortText}"
                           ToolTip="{Binding SourceTypeText}"/>

                                            <TextBlock Margin="8,0,5,0"
                           VerticalAlignment="Center"
                           Foreground="{Binding AvailabilityColor}"
                           FontSize="12"
                           Text="●"
                           ToolTip="{Binding AvailabilityToolTip}"/>

                                            <TextBlock VerticalAlignment="Center"
                           Foreground="{Binding AvailabilityColor}"
                           FontSize="12"
                           Text="{Binding AvailabilityText}"
                           ToolTip="{Binding AvailabilityToolTip}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="2"
                       Margin="0,3,0,0"
                       Foreground="#4B5563"
                       FontSize="12"
                       Text="{Binding FullPath}"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding FullPath}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>


                        </ListBox>
                    </Grid>
                </Grid>

            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          Cursor="SizeWE"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          ShowsPreview="True"/>

            <Border Grid.Column="2"
                    Padding="12"
                    Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Margin="0,0,0,12"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Text="Результаты поиска"/>

                    <StackPanel Grid.Row="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Video Archive Finder"/>

                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#6B7280"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="Добавьте источник архива, чтобы начать поиск"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Padding="12,6"
                Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="0,1,0,0">
            <TextBlock Foreground="#4B5563"
                       Text="{Binding StatusText}"/>
        </Border>
    </Grid>
</Window>
